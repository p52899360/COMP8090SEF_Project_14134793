    h = MaxHeap()
    h.insert(3)
    h.insert(8)
    h.insert(5)
    h.insert(1)
    print("Current heap elements: ", h.heap)
    print("Max element in heap: ", h.get_max())
    print("Pop max element: ", h.pop_max())
    print("Heap elements after pop: ", h.heap)





from data_structure_heap import MaxHeap

def heap_sort(arr):
    
    mh = MaxHeap()
    for num in arr:
        mh.insert(num)
    
    sorted_arr = []
    while len(mh.heap) > 0:
        max_num = mh.pop_max()
        sorted_arr.insert(0, max_num)  # Insert at head to get ascending order
    return sorted_arr


if __name__ == "__main__":
    
    test1 = [5,2,9,1,5,6]
    print("Original list: ", test1)
    print("After Heap Sort: ", heap_sort(test1))
    
    test2 = [3,1,2]
    print("Original list: ", test2)
    print("After Heap Sort: ", heap_sort(test2))

    
