class MaxHeap:
    def __init__(self):
        self.heap = []  # Store heap elements with list

    def sift_up(self, i):
        while i > 0:
            parent = (i - 1) // 2  # Parent node index
            if self.heap[i] > self.heap[parent]:
                # Swap child and parent node
                self.heap[i], self.heap[parent] = self.heap[parent], self.heap[i]
                i = parent  # Move up to parent node
            else:
                break  # No need to swap, exit loop

    def sift_down(self, i):
        n = len(self.heap)
        while True:
            left = 2 * i + 1  # Left child index
            right = 2 * i + 2 # Right child index
            max_idx = i       # Initial max index: current node
            # Find the max value among current, left and right node
            if left < n and self.heap[left] > self.heap[max_idx]:
                max_idx = left
            if right < n and self.heap[right] > self.heap[max_idx]:
                max_idx = right
            if max_idx != i:
                # Swap and continue sifting down
                self.heap[i], self.heap[max_idx] = self.heap[max_idx], self.heap[i]
                i = max_idx
            else:
                break  # No need to swap, exit loop

    def insert(self, num):
        self.heap.append(num)
        self.sift_up(len(self.heap)-1)

    def pop_max(self):
        if len(self.heap) == 0:
            print("No elements in heap, cannot pop!")
            return None
        # Swap top and last element, pop the last one
        self.heap[0], self.heap[-1] = self.heap[-1], self.heap[0]
        max_num = self.heap.pop()
        self.sift_down(0)
        return max_num

    def get_max(self):
        if len(self.heap) == 0:
            return None
        return self.heap[0]

